# FastMoney Bot P2P — Variables de entorno
# Copia este archivo como .env y completa con tus valores:
#   cp .env.example .env

# Token del bot de Telegram (obtenido de @BotFather)
BOT_TOKEN=

# ID del chat/canal donde se envian los mensajes automaticos
CHAT_ID=

# ID del propietario del bot (para comandos admin como /auto_on, /auto_off)
OWNER_ID=

# ID privado opcional (para mensajes directos de debug)
PRIVATE_ID=
